# Discord Webhook URL for match logging
# Create a webhook in your Discord server and paste the full URL here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Backend environment
RUST_LOG=info
PORT=3000

# CORS allowed origins (comma-separated for multiple)
ALLOWED_ORIGINS=https://battle-cp.vercel.app

# Oracle Cloud deployment
# Set this to deploy to your Oracle VM:
#   ORACLE_SSH_HOST=ubuntu@<YOUR_ORACLE_VM_IP>
# Then run: bash deploy_oracle.sh
ORACLE_SSH_HOST=
