# Discord Webhook URL for match logging
# Create a webhook in your Discord server and paste the full URL here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Backend environment
RUST_LOG=info
PORT=3000

# CORS allowed origin (production URL)
ALLOWED_ORIGINS=https://battle-cp.vercel.app
